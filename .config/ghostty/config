theme = Catppuccin Mocha
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

confirm-close-surface = always

# tabs
keybind = ctrl+n=new_tab
keybind = ctrl+x=close_tab:this
keybind = alt+h=previous_tab
keybind = alt+l=next_tab

# splits
keybind = ctrl+backslash=new_split:right
keybind = ctrl+digit_5=new_split:down

# move between splits
keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:down
keybind = ctrl+k=goto_split:up
keybind = ctrl+l=goto_split:right
