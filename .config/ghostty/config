theme = Catppuccin Mocha
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

# tabs
keybind = ctrl+g>n=new_tab
keybind = ctrl+g>x=close_tab:this
keybind = alt+h=previous_tab
keybind = alt+l=next_tab

# splits
keybind = ctrl+backslash=new_split:right
keybind = ctrl+digit_5=new_split:down

# move between splits (prefix ctrl+g)
keybind = ctrl+alt+h=goto_split:left
keybind = ctrl+alt+j=goto_split:down
keybind = ctrl+alt+k=goto_split:up
keybind = ctrl+alt+l=goto_split:right
